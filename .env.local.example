# Copy this file to .env.local and fill in the values.
# .env.local is gitignored; never commit it.

# ---- Anthropic ----
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ---- Supabase ----
# Create a project at https://supabase.com. Settings > API gives you these.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Stripe (for the billing phase) ----
# Dashboard > Developers > API keys
STRIPE_SECRET_KEY=
# Dashboard > Developers > Webhooks (create one, point at /api/stripe/webhook)
STRIPE_WEBHOOK_SECRET=
# Create two products: "Attest Starter" ($19/mo) and "Attest Pro" ($39/mo). Paste their price IDs here.
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# ---- Resend (optional for v0 — Supabase handles magic-link email by default) ----
RESEND_API_KEY=

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
